# ─── AI Provider Keys (at least one must be set) ─────────────────────────────
# Fallback order: Anthropic → Gemini → Groq → NVIDIA NIM

# 1. PRIMARY: Anthropic Claude Sonnet
ANTHROPIC_API_KEY=sk-ant-api03-...

# 2. FALLBACK 1: Google Gemini 2.0 Flash
#    Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_key_here

# 3. FALLBACK 2: Groq Llama-3.3-70B (ultra-fast inference)
#    Get key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# 4. FALLBACK 3: NVIDIA NIM Llama-3.1-405B (largest open model)
#    Get key: https://build.nvidia.com/
NVIDIA_NIM_API_KEY=your_nvidia_nim_key_here
